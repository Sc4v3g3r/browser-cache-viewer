# Copy to `.env` and adjust for your machine. `.env` is git-ignored.

# Default Chrome/Chromium Simple Cache directory shown in the UI.
CHROME_CACHE_DIR=~/.cache/chromium/Default/Cache/Cache_Data

# Base Firefox profiles directory; the app auto-scans for a cache2/entries folder.
FIREFOX_CACHE_BASE=~/.cache/mozilla/firefox/

# Server binding. Keep 127.0.0.1 unless you understand the exposure (see README).
HOST=127.0.0.1
PORT=5000

# Set to 1 only for local development. Never enable in a shared/production setting.
FLASK_DEBUG=0

# Max upload size (MB) for the drag-and-drop .zip endpoint.
MAX_UPLOAD_MB=500
